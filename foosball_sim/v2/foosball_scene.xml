    <!-- ════════════════════════════════════════════════════════════════════
         Visible WALLS (brown) and GOALS (white posts + crossbar)
         All visual-only (contype=0 conaffinity=0) — physics bounces
         are handled in code by the gym env.
         ════════════════════════════════════════════════════════════════════ -->

      <!-- SIDE WALLS — long brown boxes along the full length -->
      <!-- Left wall at X = -24.25 -->
      <body name="wall_left" pos="-24.75 0 3">
        <geom type="box" size="0.5 40.5 3" rgba="0.45 0.28 0.12 1"
              contype="0" conaffinity="0" group="2"/>
      </body>
      <!-- Right wall at X = +24.25 -->
