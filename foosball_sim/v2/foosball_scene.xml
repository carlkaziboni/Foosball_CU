        <geom type="box" size="0.5 40.5 3" rgba="0.45 0.28 0.12 1"
              contype="0" conaffinity="0" group="2"/>
      </body>

      <!-- END WALL — Yellow end (Y = -40.5), split around goal opening (X ±4.0) -->
      <!-- Left segment: X from -24.25 to -4.0 → half-width 10.125, center X = -14.125 -->
